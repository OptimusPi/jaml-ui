{
  "name": "jaml-ui",
  "version": "0.22.4",
  "description": "Balatro rendering components, sprite metadata, and optional Motely helpers for React apps.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./motely": {
      "import": "./dist/motely.js",
      "require": "./dist/motely.js",
      "types": "./dist/motely.d.ts",
      "default": "./dist/motely.js"
    },
    "./fonts.css": "./fonts.css",
    "./jaml.schema.json": "./jaml.schema.json"
  },
  "sideEffects": [
    "./fonts.css"
  ],
  "files": [
    "dist",
    "assets/*.png",
    "assets/fonts",
    "fonts.css",
    "dist/ui/jimbo.css",
    "jaml.schema.json",
    "README.md",
    "DESIGN.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc --pretty false && node -e \"const fs=require('fs');fs.mkdirSync('dist/ui',{recursive:true});fs.copyFileSync('src/ui/jimbo.css','dist/ui/jimbo.css');fs.copyFileSync('node_modules/motely-wasm/jaml.schema.json','jaml.schema.json');\"",
    "dev": "tsc --watch",
    "demo": "vite --config demo/vite.config.ts",
    "typecheck": "tsc --noEmit --pretty false",
    "prepack": "npm run build",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "lint": "eslint ."
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/OptimusPi/jaml-ui"
  },
  "homepage": "https://github.com/OptimusPi/jaml-ui#readme",
  "bugs": {
    "url": "https://github.com/OptimusPi/jaml-ui/issues"
  },
  "keywords": [
    "balatro",
    "jaml",
    "motely",
    "seed",
    "card",
    "sprite",
    "ui"
  ],
  "author": "pifreak",
  "license": "MIT",
  "peerDependencies": {
    "@monaco-editor/react": ">=4.0.0",
    "@react-spring/three": ">=9.0.0",
    "@react-three/drei": ">=9.0.0",
    "@react-three/fiber": ">=8.0.0",
    "monaco-editor": ">=0.50.0",
    "motely-wasm": "^14.4.0",
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0",
    "react-icons": ">=5.0.0",
    "three": ">=0.150.0"
  },
  "peerDependenciesMeta": {
    "@react-spring/three": {
      "optional": true
    },
    "@react-three/fiber": {
      "optional": true
    },
    "motely-wasm": {
      "optional": true
    },
    "react-icons": {
      "optional": true
    },
    "three": {
      "optional": true
    },
    "@react-three/drei": {
      "optional": true
    }
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.1.2",
    "@google/design.md": "^0.1.1",
    "@monaco-editor/react": "^4.7.0",
    "@react-spring/three": "^10.0.3",
    "@react-three/drei": ">=9.0.0",
    "@react-three/fiber": "^9.6.0",
    "@storybook/addon-a11y": "^10.3.6",
    "@storybook/addon-docs": "^10.3.6",
    "@storybook/addon-onboarding": "^10.3.6",
    "@storybook/addon-vitest": "^10.3.6",
    "@storybook/react-vite": "^10.3.6",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.0",
    "@vitejs/plugin-react": "^5.0.4",
    "@vitest/browser-playwright": "^4.1.5",
    "@vitest/coverage-v8": "^4.1.5",
    "clsx": "^2.1.1",
    "js-yaml": "^4.1.1",
    "lucide-react": "^1.14.0",
    "monaco-editor": "^0.55.1",
    "motely-wasm": "^14.4.0",
    "playwright": "^1.59.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-icons": "^5.6.0",
    "storybook": "^10.3.6",
    "tailwind-merge": "^2.6.1",
    "three": "^0.184.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.9",
    "vitest": "^4.1.5",
    "zustand": "^5.0.0"
  },
  "dependencies": {
    "@json-render/core": "^0.18.0",
    "@types/js-yaml": "^4.0.9"
  }
}
